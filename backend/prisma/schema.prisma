generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
}

enum PaymentProvider {
  MANUAL
  PAYSTACK
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role     @default(CASHIER)
  branch       String?
  status       UserStatus @default(ACTIVE)
  isActive     Boolean  @default(true)
  sales        Sale[]
  refunds      Refund[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([isActive])
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?  @unique
  phone         String?  @unique
  address       String?
  loyaltyPoints Int      @default(0)
  sales         Sale[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  description    String?
  sku            String         @unique
  price          Decimal        @db.Decimal(10, 2)
  stock          Int            @default(0)
  barcode        String?        @unique
  imageUrl       String?
  isActive       Boolean        @default(true)
  categoryId     Int
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  saleItems      SaleItem[]
  refundItems    RefundItem[]
  inventoryLogs  InventoryLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([name])
  @@index([sku])
  @@index([categoryId])
  @@index([isActive])
}

model Sale {
  id         Int        @id @default(autoincrement())
  subtotal   Decimal    @db.Decimal(12, 2)
  tax        Decimal    @db.Decimal(12, 2) @default(0)
  discount   Decimal    @db.Decimal(12, 2) @default(0)
  total      Decimal    @db.Decimal(12, 2)
  terminalName String?
  customerId Int?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  cashierId  String     @db.Uuid
  cashier    User       @relation(fields: [cashierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items      SaleItem[]
  payments   Payment[]
  refunds    Refund[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([customerId])
  @@index([cashierId])
  @@index([createdAt])
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refundItems RefundItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
}

model Refund {
  id            Int          @id @default(autoincrement())
  saleId         Int
  cashierId      String       @db.Uuid
  refundMethod   String
  subtotal       Decimal      @db.Decimal(12, 2)
  taxAdjustment  Decimal      @db.Decimal(12, 2) @default(0)
  total          Decimal      @db.Decimal(12, 2)
  sale           Sale         @relation(fields: [saleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cashier        User         @relation(fields: [cashierId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items          RefundItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([saleId])
  @@index([cashierId])
  @@index([createdAt])
}

model RefundItem {
  id         Int      @id @default(autoincrement())
  refundId    Int
  saleItemId  Int
  productId   Int
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  subtotal    Decimal  @db.Decimal(12, 2)
  refund      Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  saleItem    SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([refundId])
  @@index([saleItemId])
  @@index([productId])
}

model Payment {
  id                Int             @id @default(autoincrement())
  saleId            Int
  sale              Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  provider          PaymentProvider @default(MANUAL)
  status            PaymentStatus   @default(PENDING)
  method            PaymentMethod
  amountPaid        Decimal         @db.Decimal(12, 2)
  changeGiven       Decimal         @db.Decimal(12, 2) @default(0)
  reference         String?
  providerReference String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([saleId])
  @@index([provider])
  @@index([status])
  @@index([method])
  @@index([createdAt])
}

model InventoryLog {
  id              Int                   @id @default(autoincrement())
  productId       Int
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  quantityChanged Int
  type            InventoryMovementType
  reason          String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}
